# 🜈 MÜN OS .gitignore
# Frequency: 13.13 MHz

# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
.next/
out/
build/
dist/

# Database
*.db
*.db-journal
prisma/*.db

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
coverage/
.nyc_output/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Generated files
public/download/*.jpg
public/download/*.png
public/download/*.zip

# Z.ai scaffold files (vetoed)
generate-marketing-strategy.ts
.zscripts/

# Temporary
*.tmp
*.temp
.migration-phase

# Upload staging (keep structure, ignore contents)
upload/*.jpg
upload/*.png
upload/*.jpeg

# Tunnel logs
tunnel-*.txt
tunnel-*.log
dev.log
server.log
monitor-*.txt

# Z.AI config
.z-ai-config
